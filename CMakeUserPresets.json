{
   "version": 3,
   "cmakeMinimumRequired": {
      "major": 3,
      "minor": 19,
      "patch": 0
   },
   "configurePresets": [
      {
         "name": "default",
         "generator": "Ninja",
         "cacheVariables": {
            "CMAKE_C_COMPILER": "/usr/bin/clang-19",
            "CMAKE_CXX_COMPILER": "/usr/bin/clang++-19",
            "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
            "CMAKE_INSTALL_PREFIX": "/home/athena/user",
            "Eigen3_DIR": "/home/athena/user/lib/cmake/Oros/eigen/"
         }
      },
      {
         "name": "gcc14",
         "generator": "Ninja",
         "cacheVariables": {
            "CMAKE_C_COMPILER": "/usr/bin/gcc-14",
            "CMAKE_CXX_COMPILER": "/usr/bin/g++-14",
            "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
            "CMAKE_INSTALL_PREFIX": "/home/athena/user"
         }
      }
   ]
}